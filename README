== maze.c ==                                                 ##################
                                                             #                #
Escape the maze. There must be some stairs out somewhere...  #                #
                                                             #                #
  w    wasd: move one step in specified direction            #                #
  |       q: quit                                            #    #.#         #
a-.-d                                                        #    #.##        #
  |    BUILD                                                 #    ....#       #
  s        gcc -o maze maze.c -lm -lncurses                  #    ###.#######.#
                                                             #    #...@.......#
       RUN                                                   #    ###.#.#######
           ./maze                                            #      #.#.#     #
